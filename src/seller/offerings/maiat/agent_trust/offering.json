{
  "name": "agent_trust",
  "description": "Complete trust + behavioral profile for any ACP agent. Returns: trustScore 0-100, verdict (trusted/proceed/caution/avoid), completionRate, paymentRate, totalJobs, riskOutlook, behavioral analysis (trend direction, buyer diversity, wash-trading detection, payment reliability), and Wadjet ML risk signals (tokenHealth, rugProbability). All data from on-chain ACP history + Wadjet ML engine. Use when: you are about to hire, delegate to, or pay an unknown agent. If verdict is 'avoid', do not proceed.",
  "jobFee": 0.02,
  "jobFeeType": "fixed",
  "requiredFunds": false,
  "requirement": {
    "type": "object",
    "properties": {
      "agent": {
        "type": "string",
        "description": "0x wallet address of the ACP agent to check (also accepts 'wallet', 'address', or 'walletAddress')"
      },
      "wallet": {
        "type": "string",
        "description": "Alias for 'agent' — 0x wallet address"
      },
      "threshold": {
        "type": "number",
        "description": "Minimum score for proceed verdict (default: 60)"
      }
    },
    "required": ["agent"]
  },
  "deliverable": {
    "type": "object",
    "properties": {
      "score": { "type": "number", "description": "Trust score 0-100" },
      "verdict": {
        "type": "string",
        "description": "trusted | proceed | caution | avoid | unknown"
      },
      "completionRate": { "type": "number" },
      "paymentRate": { "type": "number" },
      "totalJobs": { "type": "number" },
      "ageWeeks": { "type": "number" },
      "riskOutlook": {
        "type": "string",
        "description": "stable | uncertain | deteriorating — predictive outlook"
      },
      "riskSummary": { "type": "string", "description": "One-line human-readable summary" },
      "behavioral": {
        "type": "object",
        "description": "Deep behavioral analysis",
        "properties": {
          "trendDirection": {
            "type": "string",
            "description": "improving | declining | stable | unknown"
          },
          "buyerDiversityScore": {
            "type": "number",
            "description": "0-100, higher = more diverse clients"
          },
          "singleBuyerRisk": {
            "type": "boolean",
            "description": "True if >80% jobs from one buyer (wash trading signal)"
          },
          "paymentReliability": {
            "type": "string",
            "description": "excellent | good | concerning | poor"
          }
        }
      },
      "tokenHealth": {
        "type": "object",
        "description": "Token risk data from Wadjet (if agent has a token)",
        "properties": {
          "tokenAddress": { "type": "string" },
          "rugProbability": { "type": "number", "description": "0-1, higher = riskier" },
          "riskLevel": { "type": "string" },
          "confidence": { "type": "number" }
        }
      },
      "lastUpdated": { "type": "string" }
    }
  }
}
