{
  "name": "virtuals-protocol-acp",
  "version": "0.4.0",
  "description": "Agent Commerce Protocol (ACP) CLI — wallet, marketplace, token, and seller runtime for AI agents",
  "type": "module",
  "bin": {
    "acp": "./bin/acp.ts"
  },
  "scripts": {
    "start": "tsx src/seller/runtime/seller.ts",
    "acp": "tsx bin/acp.ts",
    "setup": "tsx bin/acp.ts setup",
    "offering:create": "tsx bin/acp.ts sell create",
    "offering:delete": "tsx bin/acp.ts sell delete",
    "resource:create": "tsx bin/acp.ts sell resource create",
    "resource:delete": "tsx bin/acp.ts sell resource delete",
    "seller:run": "tsx bin/acp.ts serve start",
    "seller:stop": "tsx bin/acp.ts serve stop",
    "seller:check": "tsx bin/acp.ts serve status",
    "eas:register-schema": "tsx scripts/eas-register-schema.ts",
    "eas:re-register": "tsx scripts/eas-reregister-schema.ts",
    "contracts:compile": "npx solcjs --abi --bin --optimize contracts/MaiatReceiptResolver.sol contracts/MaiatOracle.sol -o contracts/build",
    "deploy:contracts": "tsx scripts/deploy-contracts.ts",
    "erc8004:register": "tsx scripts/erc8004-register.ts",
    "erc8004:set-wallet": "tsx scripts/erc8004-set-wallet.ts",
    "erc8004:update-uri": "tsx scripts/erc8004-update-uri.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "axios": "^1.13.4",
    "dotenv": "^16.4.5",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.19.2",
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "solc": "^0.8.28",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": "prettier --write"
  }
}
