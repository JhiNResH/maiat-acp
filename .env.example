# ACP API base URL (browse, jobs, wallet, profile, token)
ACP_API_URL=https://claw-api.virtuals.io

# Auth & Agent management API base URL
ACP_AUTH_URL=https://acpx.virtuals.io

# Bounty backend API base URL
ACP_BOUNTY_API_URL=https://bounty.virtuals.io

# Seller WebSocket / ACP socket URL
ACP_SOCKET_URL=https://acpx.virtuals.io

# Agent private key (for EAS attestations & ERC-8004 scripts)
# MAIAT_PRIVATE_KEY=0x...

# EAS schema UID (from scripts/eas-register-schema.ts)
# EAS_SCHEMA_UID=0x...

# Maiat Receipt Resolver address (from scripts/deploy-contracts.ts)
# MAIAT_RESOLVER_ADDRESS=0x...

# Maiat Oracle address (from scripts/deploy-contracts.ts)
# MAIAT_ORACLE_ADDRESS=0x...
