{
  "name": "Deep Insight Report",
  "description": "AI-powered deep analysis of crypto projects. Includes project signals, risk factors, on-chain warnings, trust score breakdown, and review sentiment analysis.",
  "jobFee": 0.10,
  "jobFeeType": "fixed",
  "requiredFunds": false,
  "requirements": {
    "type": "object",
    "properties": {
      "project": {
        "type": "string",
        "description": "Project name or contract address"
      },
      "depth": {
        "type": "string",
        "enum": ["basic", "premium", "deep"],
        "description": "Analysis depth level (default: deep)"
      }
    },
    "required": ["project"]
  },
  "deliverable": {
    "type": "object",
    "properties": {
      "project": { "type": "string" },
      "category": { "type": "string" },
      "analysis": {
        "type": "object",
        "properties": {
          "score": { "type": "number" },
          "status": { "type": "string" },
          "summary": { "type": "string" },
          "features": { "type": "array", "items": { "type": "string" } },
          "warnings": { "type": "array", "items": { "type": "string" } }
        }
      },
      "reviews": {
        "type": "object",
        "properties": {
          "total": { "type": "number" },
          "verified": { "type": "number" },
          "avgRating": { "type": "number" }
        }
      },
      "recommendation": {
        "type": "object",
        "properties": {
          "signals": { "type": "array", "items": { "type": "string" } },
          "verdict": { "type": "string" },
          "confidence": { "type": "string" }
        }
      },
      "maiats_gift": { "type": "string" }
    }
  }
}
